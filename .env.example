# ============================================================
# SEM-Swarm — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#
# Architecture based on the "Cognitive Minimum Privilege" principle:
# Each model receives exactly the intellectual capacity its task requires.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sem_swarm
POSTGRES_USER=sem_admin
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# ── Ollama Local (Notebook — Interatividade) ─────────────────
OLLAMA_LOCAL_URL=http://localhost:11434

# Orquestrador Central — Phi-4-Mini (3.8B, ~3-4 GB RAM)
# Responsável por: tool calling, MCP, chat, planejamento
# Justificativa: vocabulário 200k (PT-BR fluente), GQA, 128k contexto,
#                líder no Berkeley Function Calling Leaderboard
OLLAMA_ORCHESTRATOR_MODEL=phi4-mini

# Extrator JSON Determinístico — NuExtract (3.8B, ~2-3 GB RAM)
# Responsável por: extração estruturada, conversão text→JSON/Pydantic
# Justificativa: treinado sinteticamente para extração pura,
#                supera generalistas <10B que atingem apenas 28-33% accuracy
OLLAMA_EXTRACTOR_MODEL=nuextract

# Copiloto FIM / Autocompletar — Qwen2.5-Coder (1.5B, ~1.5 GB RAM)
# Responsável por: EXCLUSIVAMENTE Fill-in-the-Middle na IDE
# NÃO usar para orquestração ou tool calling (diluição de atenção)
OLLAMA_FIM_MODEL=qwen2.5-coder:1.5b

# Conselheiro Consultivo — Qwen3 (8B, ~6-8 GB RAM)
# Responsável por: lógica complexa, refatoração profunda (sob demanda)
OLLAMA_REASONING_MODEL=qwen3:8b

# ── Ollama VPS (Boston — Assíncrono/Persistente) ─────────────
OLLAMA_VPS_URL=http://YOUR_VPS_IP:11434

# Embeddings Multilíngues — Qwen3-Embedding (8B)
# Responsável por: vetorização semântica em 100+ idiomas, 32k contexto
# Roda na VPS para liberar RAM do notebook
OLLAMA_EMBED_MODEL=qwen3-embedding
EMBEDDING_DIM=2048

# Raciocínio Profundo Assíncrono — DeepSeek-R1 (14B, ~9 GB RAM)
# Responsável por: Dreaming Loop, análises noturnas, planos arquiteturais
# Roda via nohup/screen, não bloqueante
OLLAMA_DEEP_REASONING_MODEL=deepseek-r1:14b
